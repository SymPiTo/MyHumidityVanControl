{
    "elements": [
        { 
        "type": "CheckBox", 
        "name": "Active", 
        "caption": "Modul aktivieren" 
        },
        {
            "type": "Label",
            "caption": "Wähle hier den Feuchtigkeitssensor und den Zigbee-Aktor aus."
        },
        {
            "type": "SelectVariable",
            "name": "SensorID",
            "caption": "Feuchtigkeits-Sensor (Humidity %)"
        },
        {
            "type": "SelectInstance",
            "name": "TargetID",
            "caption": "Lüfter Aktor (Z2M Instanz)"
        },
        {
            "type": "SelectInstance",
            "name": "SwitchID",
            "caption": "ZigBee Schalter (Z2M Instanz)"
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Lüfter Test AN",
            "onClick": "MHVC_StartFan($id);"
        },
        {
            "type": "Button",
            "caption": "Lüfter Test AUS",
            "onClick": "MHVC_StopFan($id);"
        }
    ]
}



